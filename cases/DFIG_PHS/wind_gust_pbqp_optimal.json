{
  "description": "IEEE 14-bus DFIG PBQP-PHS \u2014 Wind gust (analytically optimal: \u03b1_tw=50, \u03b1_ff=130)",
  "system": "cases/DFIG_PHS/ieee14_dfig_pbqp_wind_optimal.json",
  "solver": {
    "dt": 0.0005,
    "duration": 60.0,
    "method": "bdf1"
  },
  "output": {
    "directory": "outputs/DFIG_MPC_wind_optimal"
  },
  "events": [],
  "plots": [
    {
      "title": "Terminal Voltages",
      "y_label": "Vterm [pu]",
      "signals": [
        {
          "pattern": "Vterm_Bus*"
        }
      ]
    },
    {
      "title": "Grid Frequency (GENCLS)",
      "y_label": "\u03c9 [pu]",
      "signals": [
        {
          "pattern": "GENCLS_1.omega"
        }
      ]
    },
    {
      "title": "DFIG Generator Speeds",
      "y_label": "\u03c9_g [pu]",
      "signals": [
        {
          "pattern": "DFIG_PHS_*.omega_pu"
        }
      ]
    },
    {
      "title": "DFIG Active Power",
      "y_label": "Pe [pu]",
      "signals": [
        {
          "pattern": "DFIG_PHS_*.Pe"
        }
      ]
    },
    {
      "title": "DFIG Reactive Power",
      "y_label": "Qe [pu]",
      "signals": [
        {
          "pattern": "DFIG_PHS_*.Qe"
        }
      ]
    },
    {
      "title": "DFIG Terminal Voltage",
      "y_label": "Vt [pu]",
      "signals": [
        {
          "pattern": "DFIG_PHS_*.V_term"
        }
      ]
    },
    {
      "title": "Torsional Torques \u2014 T_shaft vs Te vs T_aero (DFIG 1)",
      "y_label": "Torque [pu]",
      "signals": [
        {
          "pattern": "DFIG_DT_PHS_1.T_shaft"
        },
        {
          "pattern": "DFIG_PHS_1.Te_elec"
        },
        {
          "pattern": "DFIG_DT_PHS_1.T_aero"
        }
      ]
    },
    {
      "title": "Shaft Twist Rate",
      "y_label": "\u0394\u03c9 [pu]",
      "signals": [
        {
          "pattern": "DFIG_DT_PHS_*.twist_rate"
        }
      ]
    },
    {
      "title": "Shaft Twist Angle \u03b8_tw",
      "y_label": "\u03b8_tw [rad]",
      "signals": [
        {
          "pattern": "DFIG_DT_PHS_*.theta_tw"
        }
      ]
    },
    {
      "title": "Drivetrain \u2014 Turbine Speeds",
      "y_label": "\u03c9_t [pu]",
      "signals": [
        {
          "pattern": "DFIG_DT_PHS_*.omega_t"
        }
      ]
    },
    {
      "title": "PB-QP RSC \u2014 Rotor Voltage Commands",
      "y_label": "Vr [pu]",
      "signals": [
        {
          "pattern": "DFIG_RSC_PBQP_PHS_*.Vrd_cmd"
        },
        {
          "pattern": "DFIG_RSC_PBQP_PHS_*.Vrq_cmd"
        }
      ]
    },
    {
      "title": "PB-QP RSC \u2014 Virtual Frequency",
      "y_label": "\u03c9_vs [pu]",
      "signals": [
        {
          "pattern": "DFIG_RSC_PBQP_PHS_*.omega_vs"
        }
      ]
    }
  ]
}