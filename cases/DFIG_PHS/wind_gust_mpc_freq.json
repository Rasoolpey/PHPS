{
  "description": "IEEE 14-bus DFIG Freq-MPC-PHS — Wind gust with predictive torsional damping",
  "system": "cases/DFIG_PHS/ieee14_dfig_mpc_freq_wind.json",
  "solver": {
    "dt": 0.0005,
    "duration": 60.0,
    "method": "bdf1"
  },
  "output": {
    "directory": "outputs/DFIG_MPC_FREQ_wind"
  },
  "events": [],
  "plots": [
    {
      "title": "Terminal Voltages",
      "y_label": "Vterm [pu]",
      "signals": [
        { "pattern": "Vterm_Bus*" }
      ]
    },
    {
      "title": "Grid Frequency (GENCLS)",
      "y_label": "ω [pu]",
      "signals": [
        { "pattern": "GENCLS_1.omega" }
      ]
    },
    {
      "title": "DFIG Generator Speeds",
      "y_label": "ω_g [pu]",
      "signals": [
        { "pattern": "DFIG_PHS_*.omega_pu" }
      ]
    },
    {
      "title": "DFIG Active Power",
      "y_label": "Pe [pu]",
      "signals": [
        { "pattern": "DFIG_PHS_*.Pe" }
      ]
    },
    {
      "title": "DFIG Reactive Power",
      "y_label": "Qe [pu]",
      "signals": [
        { "pattern": "DFIG_PHS_*.Qe" }
      ]
    },
    {
      "title": "DFIG Terminal Voltage",
      "y_label": "Vt [pu]",
      "signals": [
        { "pattern": "DFIG_PHS_*.V_term" }
      ]
    },
    {
      "title": "Torsional Torques — T_shaft vs Te vs T_aero (DFIG 1)",
      "y_label": "Torque [pu]",
      "signals": [
        { "pattern": "DFIG_DT_PHS_1.T_shaft" },
        { "pattern": "DFIG_PHS_1.Te_elec" },
        { "pattern": "DFIG_DT_PHS_1.T_aero" }
      ]
    },
    {
      "title": "Shaft Twist Rate (ω_t − ω_g)",
      "y_label": "Δω [pu]",
      "signals": [
        { "pattern": "DFIG_DT_PHS_*.twist_rate" }
      ]
    },
    {
      "title": "Shaft Twist Angle θ_tw",
      "y_label": "θ_tw [rad]",
      "signals": [
        { "pattern": "DFIG_DT_PHS_*.theta_tw" }
      ]
    },
    {
      "title": "Drivetrain — Turbine Speeds",
      "y_label": "ω_t [pu]",
      "signals": [
        { "pattern": "DFIG_DT_PHS_*.omega_t" }
      ]
    },
    {
      "title": "MPC RSC — Rotor Voltage Commands",
      "y_label": "Vr [pu]",
      "signals": [
        { "pattern": "DFIG_RSC_MPC_FREQ_PHS_*.Vrd_cmd" },
        { "pattern": "DFIG_RSC_MPC_FREQ_PHS_*.Vrq_cmd" }
      ]
    },
    {
      "title": "MPC RSC — Virtual Frequency (APC)",
      "y_label": "ω_vs [pu]",
      "signals": [
        { "pattern": "DFIG_RSC_MPC_FREQ_PHS_*.omega_vs" }
      ]
    }
  ]
}
