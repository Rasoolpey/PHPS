{
  "description": "IEEE 14-bus DFIG MPC-PHS — Fault at Bus 4 — Multi-Horizon Lyapunov-MPC (N=3), torsional damping",
  "system": "cases/DFIG_PHS/ieee14_dfig_mpc_phs.json",
  "solver": {
    "dt": 0.0005,
    "duration": 60.0,
    "method": "bdf1"
  },
  "output": {
    "directory": "outputs/DFIG_MPC_PHS_fault"
  },
  "events": [
    {
      "type": "BusFault",
      "bus": 4,
      "r": 0.0001,
      "x": 0.0001,
      "t_start": 20.0,
      "t_duration": 5,
      "fault_type": "3phase"
    }
  ],
  "plots": [
    {
      "title": "Terminal Voltages",
      "y_label": "Vterm [pu]",
      "signals": [
        { "pattern": "Vterm_Bus*" }
      ]
    },
    {
      "title": "Grid Frequency (GENCLS)",
      "y_label": "ω [pu]",
      "signals": [
        { "pattern": "GENCLS_1.omega" }
      ]
    },
    {
      "title": "DFIG Generator Speeds",
      "y_label": "ω_r [pu]",
      "signals": [
        { "pattern": "DFIG_PHS_*.omega_pu" }
      ]
    },
    {
      "title": "DFIG Active Power",
      "y_label": "Pe [pu]",
      "signals": [
        { "pattern": "DFIG_PHS_*.Pe" }
      ]
    },
    {
      "title": "DFIG Reactive Power",
      "y_label": "Qe [pu]",
      "signals": [
        { "pattern": "DFIG_PHS_*.Qe" }
      ]
    },
    {
      "title": "DFIG Terminal Voltage",
      "y_label": "Vt [pu]",
      "signals": [
        { "pattern": "DFIG_PHS_*.V_term" }
      ]
    },
    {
      "title": "DFIG Slip",
      "y_label": "slip [-]",
      "signals": [
        { "pattern": "DFIG_PHS_*.slip" }
      ]
    },
    {
      "title": "MPC RSC — Virtual Frequency (APC)",
      "y_label": "ω_vs [pu]",
      "signals": [
        { "pattern": "DFIG_RSC_MPC_PHS_*.omega_vs" }
      ]
    },
    {
      "title": "MPC RSC — Rotor Voltage Commands",
      "y_label": "Vr [pu]",
      "signals": [
        { "pattern": "DFIG_RSC_MPC_PHS_*.Vrd_cmd" },
        { "pattern": "DFIG_RSC_MPC_PHS_*.Vrq_cmd" }
      ]
    },
    {
      "title": "GSC Input — DC Link Voltage",
      "y_label": "Vdc [pu]",
      "signals": [
        { "pattern": "DFIG_DCLink_PHS_*.V_dc" }
      ]
    },
    {
      "title": "Drivetrain — Turbine Speed & Shaft Torque",
      "y_label": "[pu]",
      "signals": [
        { "pattern": "DFIG_DT_PHS_*.omega_t" },
        { "pattern": "DFIG_DT_PHS_*.T_shaft" }
      ]
    },
    {
      "title": "Torsional Torques — T_shaft vs Te (MPC control action)",
      "y_label": "Torque [pu]",
      "signals": [
        { "pattern": "DFIG_DT_PHS_1.T_shaft" },
        { "pattern": "DFIG_PHS_1.Te_elec" },
        { "pattern": "DFIG_DT_PHS_1.T_aero" }
      ]
    },
    {
      "title": "Shaft Twist Rate (ω_t − ω_r) — Torsional Oscillation",
      "y_label": "Δω [pu]",
      "signals": [
        { "pattern": "DFIG_DT_PHS_*.twist_rate" }
      ]
    },
    {
      "title": "Shaft Twist Angle θ_tw",
      "y_label": "θ_tw [rad]",
      "signals": [
        { "pattern": "DFIG_DT_PHS_*.theta_tw" }
      ]
    }
  ]
}
