{
  "description": "IEEE 14-Bus DAE (IDA) — PF-matched parameters, 3-phase fault at Bus 4",
  "system": "system_pf_match.json",

  "solver": {
    "method": "ida",
    "dt": 0.0005,
    "duration": 15.0
  },

  "warm_start": {
    "csv": "../../outputs/IEEE14Bus_pfmatch_fault/warmstart_pf.csv",
    "t": 0.0,
    "delta_unwrap": {},
    "omega_override": 1.0
  },

  "events": [
    {
      "type": "BusFault",
      "bus": 4,
      "r": 0.0001,
      "x": 0.0001,
      "t_start": 2.0,
      "t_duration": 0.05
    }
  ],

  "output": {
    "directory": "outputs/IEEE14Bus_pfmatch_fault"
  },

  "plots": [
    {
      "title": "Terminal Voltages",
      "y_label": "Vterm [pu]",
      "signals": [
        { "pattern": "Vterm_Bus*" }
      ]
    },
    {
      "title": "Rotor Angles",
      "y_label": "δ [rad]",
      "signals": [
        { "pattern": "GENROU*delta" }
      ]
    },
    {
      "title": "Rotor Speeds",
      "y_label": "ω [pu]",
      "signals": [
        { "pattern": "GENROU*omega" }
      ]
    },
    {
      "title": "Field Voltages",
      "y_label": "Efd [pu]",
      "signals": [
        { "pattern": "EXST1*Efd" }
      ]
    }
  ]
}