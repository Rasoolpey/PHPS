{
  "description": "IEEE 39-Bus DAE (IDA) — PHS models, 3-phase fault at Bus 2",
  "system": "system_phs.json",

  "solver": {
    "method": "ida",
    "dt": 0.0005,
    "duration": 15.0
  },

  "events": [
    {
      "type": "BusFault",
      "bus": 2,
      "r": 0.0001,
      "x": 0.0001,
      "t_start": 1.0,
      "t_duration": 0.4
    }
  ],

  "output": {
    "directory": "outputs/IEEE39Bus_phs_fault"
  },

  "plots": [
    {
      "title": "Terminal Voltages",
      "y_label": "Vterm [pu]",
      "signals": [
        { "pattern": "Vterm_Bus*" }
      ]
    },
    {
      "title": "Rotor Angles",
      "y_label": "δ [rad]",
      "signals": [
        { "pattern": "GENROU*delta" }
      ]
    },
    {
      "title": "Rotor Speeds",
      "y_label": "ω [pu]",
      "signals": [
        { "pattern": "GENROU*omega" }
      ]
    },
    {
      "title": "Field Voltages",
      "y_label": "Efd [pu]",
      "signals": [
        { "pattern": "IEEEX1*Efd" }
      ]
    }
  ]
}
